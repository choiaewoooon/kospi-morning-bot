# ============================================================
# 코스피 모닝브리핑 봇 - 환경변수 설정
# cp .env.example .env
# ============================================================

# --- Telegram (필수) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@ozzycanton

# --- 뉴스 수집 ---
# https://newsapi.org 에서 무료 키 발급
NEWSAPI_KEY=your_newsapi_key_here
# RapidAPI Twitter API45 (선택, 트위터 뉴스 수집용)
RAPIDAPI_KEY=

# --- 스케줄 ---
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=40
TIMEZONE=Asia/Seoul
